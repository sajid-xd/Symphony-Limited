@model SymphonyLimited.Models.Registration
@{
    ViewData["Title"] = "Register";
}

<main class="flex-1 flex items-center justify-center p-6 bg-slate-50 dark:bg-slate-950">
    <div class="w-full max-w-[800px]">
        <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] p-8 md:p-14 shadow-2xl shadow-primary/5 border border-slate-100 dark:border-slate-800 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-48 h-48 bg-primary/5 rounded-full -mr-24 -mt-24 transition-transform group-hover:scale-110"></div>
            
            <div class="relative mb-12 text-center md:text-left">
                <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg shadow-primary/30 mx-auto md:mx-0">
                    <span class="material-symbols-outlined text-3xl">person_add</span>
                </div>
                <h1 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-2">Create Account</h1>
                <p class="text-slate-500 dark:text-slate-400 font-medium text-lg">Join Symphony Limited and embark on your IT certification journey</p>
            </div>

            <form asp-action="Registration" method="post" class="space-y-8">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger text-sm font-bold bg-red-50 dark:bg-red-900/20 p-4 rounded-xl border border-red-100 dark:border-red-900/30"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Full Name</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">person</span>
                            <input asp-for="FullName" class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="John Doe" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger text-xs font-bold px-1"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Username</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">alternate_email</span>
                            <input asp-for="Username" class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="johndoe123" required />
                        </div>
                        <span asp-validation-for="Username" class="text-danger text-xs font-bold px-1"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Email Address</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
                            <input asp-for="Email" class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="name@example.com" type="email" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger text-xs font-bold px-1"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Phone Number</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">call</span>
                            <input asp-for="PhoneNumber" class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="+1 (555) 000-0000" required />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger text-xs font-bold px-1"></span>
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Physical Address</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">location_on</span>
                            <input asp-for="Address" class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="123 Main St, Suite 100" required />
                        </div>
                        <span asp-validation-for="Address" class="text-danger text-xs font-bold px-1"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Password</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
                            <input asp-for="Password" type="password" class="w-full pl-12 pr-12 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="••••••••" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger text-xs font-bold px-1"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Confirm Password</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock_reset</span>
                            <input asp-for="ConfirmPassword" type="password" class="w-full pl-12 pr-12 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="••••••••" required />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger text-xs font-bold px-1"></span>
                    </div>
                </div>

                <div class="flex items-start gap-3 px-1 pt-2">
                    <input type="checkbox" required class="w-5 h-5 rounded-md border-slate-300 text-primary focus:ring-primary transition-all cursor-pointer mt-1" />
                    <label class="text-sm font-semibold text-slate-600 dark:text-slate-400 cursor-pointer select-none">
                        I agree to the <a href="#" class="text-primary hover:underline">Terms of Service</a> and <a href="#" class="text-primary hover:underline">Privacy Policy</a>
                    </label>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-5 rounded-2xl shadow-xl shadow-primary/25 transition-all flex items-center justify-center gap-3 text-lg">
                        Create My Account <span class="material-symbols-outlined">person_add</span>
                    </button>
                </div>
            </form>

            <div class="mt-10 pt-8 border-t border-slate-100 dark:border-slate-800 text-center">
                <p class="text-slate-500 dark:text-slate-400 font-medium">
                    Already have an account? 
                    <a asp-action="Logins" asp-controller="Account" class="text-primary font-bold hover:underline ml-1">Sign In instead</a>
                </p>
            </div>
        </div>
    </div>
</main>