@model SymphonyLimited.Models.ExamEnrollment

@{
    ViewData["Title"] = "Enrollment Successful";
}

<main class="w-full bg-slate-50 dark:bg-slate-950 pb-20 pt-16 min-h-screen">
    <div class="max-w-2xl mx-auto px-6 text-center">
        <!-- Success Animation/Icon -->
        <div class="mb-10 flex justify-center">
            <div class="w-24 h-24 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-500 rounded-full flex items-center justify-center shadow-lg shadow-emerald-500/20">
                <span class="material-symbols-outlined text-5xl">task_alt</span>
            </div>
        </div>

        <h1 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white mb-4">Exam <span class="text-emerald-500">Confirmed</span></h1>
        <p class="text-slate-500 text-lg mb-12">Your application for the @Model.Course.CourseName program entrance exam has been generated successfully.</p>

        <!-- Ticket Card -->
        <div class="bg-white dark:bg-slate-900 rounded-[2rem] shadow-2xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-800 p-8 md:p-12 relative overflow-hidden text-center">
            <!-- Decorative ticket cutouts -->
            <div class="absolute -left-6 top-1/2 w-12 h-12 bg-slate-50 dark:bg-slate-950 rounded-full border-r border-t border-slate-100 dark:border-slate-800"></div>
            <div class="absolute -right-6 top-1/2 w-12 h-12 bg-slate-50 dark:bg-slate-950 rounded-full border-l border-b border-slate-100 dark:border-slate-800"></div>
            
            <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">Your Hall Ticket Number</p>
            <div class="bg-primary/5 border-2 border-dashed border-primary/20 rounded-2xl p-6 mb-8 w-fit mx-auto px-12">
                <span class="text-3xl md:text-4xl font-black text-primary font-mono tracking-wider">@Model.HallTicketNumber</span>
            </div>
            
            <p class="text-sm text-slate-500 max-w-sm mx-auto mb-8">Please save this Hall Ticket number. You will need it to check your results or gain entry to the exam hall.</p>

            <div class="grid grid-cols-2 gap-y-6 text-left border-t border-slate-100 dark:border-slate-800 pt-8 border-dashed">
                <div>
                    <p class="text-xs text-slate-500 mb-1 cursor-default">Applicant</p>
                    <p class="font-bold text-slate-900 dark:text-white">@Model.UserEmail</p>
                </div>
                <div>
                    <p class="text-xs text-slate-500 mb-1 cursor-default">Target Course</p>
                    <p class="font-bold text-slate-900 dark:text-white">@Model.Course.CourseName</p>
                </div>
                <div>
                    <p class="text-xs text-slate-500 mb-1 cursor-default">Exam Date</p>
                    <p class="font-bold text-slate-900 dark:text-white">@Model.EntranceExam.ExamDate.ToString("MMM dd, yyyy")</p>
                </div>
                <div>
                    <p class="text-xs text-slate-500 mb-1 cursor-default">Status</p>
                    <span class="inline-block px-3 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-lg uppercase tracking-wide">@Model.Status</span>
                </div>
            </div>
        </div>

        <div class="mt-12 flex justify-center gap-4">
            <a asp-action="Index" class="px-8 py-4 rounded-xl bg-slate-200 dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-bold hover:bg-slate-300 transition-colors">Back to Dashboard</a>
            <button onclick="window.print()" class="px-8 py-4 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold flex items-center gap-2 shadow-lg shadow-primary/25 transition-all">
                Print Ticket <span class="material-symbols-outlined text-sm">print</span>
            </button>
        </div>
    </div>
</main>
