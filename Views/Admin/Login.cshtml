@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            /* Same Emerald Green color from your screenshot */
            background: #50C878;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-box {
            width: 400px;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .login-title {
            font-weight: bold;
            color: #2e7d32; /* Darker green for title */
        }

        /* Styling the button to match the theme */
        .btn-custom {
            background-color: #2e7d32;
            color: white;
            border: none;
            transition: 0.3s;
        }

            .btn-custom:hover {
                background-color: #1b5e20;
                color: white;
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }

        .form-control:focus {
            border-color: #50C878;
            box-shadow: 0 0 0 0.25rem rgba(80, 200, 120, 0.25);
        }
    </style>
</head>

<body>

    <div class="login-box">

        <div class="card">

            <div class="card-body p-4">

                <h3 class="text-center login-title mb-4">Admin Login</h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form method="post">

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" name="username" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required />
                    </div>

                    <div class="d-grid mt-4">
                        <button class="btn btn-custom py-2">Login</button>
                    </div>

                </form>

            </div>

        </div>

    </div>

</body>
</html>