@model SymphonyLimited.Models.Login
@{
    ViewData["Title"] = "Login";
}

<main class="flex-1 flex items-center justify-center p-6 bg-slate-50 dark:bg-slate-950 min-h-[80vh]">
    <div class="w-full max-w-[480px]">
        <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] p-10 md:p-14 shadow-2xl shadow-primary/5 border border-slate-100 dark:border-slate-800 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -mr-16 -mt-16 transition-transform group-hover:scale-110"></div>
            
            <div class="relative mb-10 text-center">
                <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center text-white mx-auto mb-6 shadow-lg shadow-primary/30">
                    <span class="material-symbols-outlined text-3xl">login</span>
                </div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-2">Welcome Back</h1>
                <p class="text-slate-500 dark:text-slate-400 font-medium">Continue your excellence journey</p>
            </div>

            <form asp-action="Logins" asp-controller="Account" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger text-sm font-bold bg-red-50 dark:bg-red-900/20 p-4 rounded-xl border border-red-100 dark:border-red-900/30"></div>

                <div class="space-y-2">
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Email or Username</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
                        <input asp-for="EmailOrUsername" class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="email@example.com or admin123" required />
                    </div>
                    <span asp-validation-for="EmailOrUsername" class="text-danger text-xs font-bold px-1"></span>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-1">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Password</label>
                        <a href="#" class="text-xs font-bold text-primary hover:underline">Forgot?</a>
                    </div>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
                        <input asp-for="Password" type="password" class="w-full pl-12 pr-12 py-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="••••••••" required />
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                            <span class="material-symbols-outlined text-xl">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger text-xs font-bold px-1"></span>
                </div>

                <div class="flex items-center gap-3 px-1">
                    <input asp-for="RememberMe" type="checkbox" class="w-5 h-5 rounded-md border-slate-300 text-primary focus:ring-primary transition-all cursor-pointer" />
                    <label asp-for="RememberMe" class="text-sm font-semibold text-slate-600 dark:text-slate-400 cursor-pointer select-none">Remember this device</label>
                </div>

                <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-5 rounded-2xl shadow-xl shadow-primary/25 transition-all flex items-center justify-center gap-3 text-lg">
                    Sign In <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-slate-100 dark:border-slate-800 text-center">
                <p class="text-slate-500 dark:text-slate-400 font-medium">
                    Don't have an account? 
                    <a asp-action="Registration" asp-controller="Account" class="text-primary font-bold hover:underline ml-1">Join Now</a>
                </p>
            </div>
        </div>
    </div>
</main>