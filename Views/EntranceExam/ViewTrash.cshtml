@model IEnumerable<SymphonyLimited.Models.EntranceExam>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<main style="margin-top: 58px">
    <div class="container pt-4">
        <section>
            <div class="container-fluid mt-4">
                <table id="coursesTable" class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>SNo #</th>
                            <th>Exam Date</th>
                            <th>Exam Fees</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 0;
                        }
                        @if (Model != null && Model.Any())
                        {
                            foreach (var course in Model)
                            {
                                i++;
                                <tr>
                                    <td>@i</td>
                                    <td>@course.ExamDate.ToString("dd/MM/yyyy")</td>
                                    <td>@course.ExamFees.ToString("N2")</td>
                                    <td>@course.Description</td>
                                    <td>
                                        <a asp-action="Restore" asp-route-id="@course.EntranceExamId" class="btn btn-sm btn-danger">Restore</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No Exam available</td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </section>
        <!--Section: Statistics with subtitles-->
    </div>
</main>