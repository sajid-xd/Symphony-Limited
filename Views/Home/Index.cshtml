        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-end mb-12">
                <div>
                    <h2 class="text-4xl font-bold text-slate-900 dark:text-white">New Courses</h2>
                    <p class="text-slate-500 mt-2">The latest additions to our curriculum for @DateTime.Now.Year.</p>
                </div>
                <a class="text-primary font-bold flex items-center gap-1 hover:underline" href="/Home/courses">
                    View all courses <span class="material-symbols-outlined">arrow_forward</span>
                </a>
            </div>
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Course Card 1 -->
                <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all">
                    <div class="h-48 overflow-hidden bg-slate-200">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCOHgsce7dPKme6okRXeHP2mpn4Uo7KZDblr9PCqYCYyJgogekQQvG1z0rPhrvpqf_-q-jJHk0-bB4LvVpbWwtdbfqdBKn7wJPsypjO27XjZev9lUJ_JEesRDpnM6t5ZeMLE5zAw0DrYVb9rXfRiJTjS0Jzet96chpC5ZKaLV-ObGtkr3FsY74TgD2l8FmYak9G2U0T1dRdQ1CcBKFBOM3To-bAH8jwq9f-31gOznpS7vRI4rrHxZLuACnRkz9Jc7YAdsleSXkfaC4" />
                    </div>
                    <div class="p-6">
                        <span class="px-2 py-1 rounded-md bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 text-[10px] font-bold uppercase tracking-wider">Software Development</span>
                        <h3 class="text-xl font-bold mt-3 mb-2 text-slate-900 dark:text-white">Advanced Java Microservices</h3>
                        <p class="text-slate-500 text-sm mb-6 line-clamp-2">Master Spring Boot, Docker, and Kubernetes for building scalable enterprise applications.</p>
                        <div class="flex items-center justify-between border-t border-slate-100 dark:border-slate-700 pt-4">
                            <span class="text-lg font-bold text-slate-900 dark:text-white">$299</span>
                            <a href="/Home/courses" class="text-primary font-bold text-sm">Enroll Now</a>
                        </div>
                    </div>
                </div>
                <!-- Course Card 2 -->
                <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all">
                    <div class="h-48 overflow-hidden bg-slate-200">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBtGZk0UeeswGjMuVxuyguEk15oRBea53foIo7EZt1KpMhgQpCv_V7zJ-Dbl4lDkLI7wITVfoZA1o_JABPPEM9GmzLalpCRfYwYSdRr2FIprYVY7zX-ktLIWyuHI80pgP8RQuh9NTCyjxi_x_XeJgPQkLBT7odIGqxqOgGq33z-UcW2J9RPyX4supE_l94rWyI4rCjXn8xrnFOuIv4GGNupn30aIslRdJWdcx6HRT3APKf4OV3KoUvIG6guJ_IcinmKaSHJAz67sgY" />
                    </div>
                    <div class="p-6">
                        <span class="px-2 py-1 rounded-md bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 text-[10px] font-bold uppercase tracking-wider">Networking & Cloud</span>
                        <h3 class="text-xl font-bold mt-3 mb-2 text-slate-900 dark:text-white">Cisco Certified DevNet</h3>
                        <p class="text-slate-500 text-sm mb-6 line-clamp-2">Automate network operations with Python and modern DevOps tools on Cisco hardware.</p>
                        <div class="flex items-center justify-between border-t border-slate-100 dark:border-slate-700 pt-4">
                            <span class="text-lg font-bold text-slate-900 dark:text-white">$349</span>
                            <a href="/Home/courses" class="text-primary font-bold text-sm">Enroll Now</a>
                        </div>
                    </div>
                </div>
                <!-- Course Card 3 -->
                <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all">
                    <div class="h-48 overflow-hidden bg-slate-200">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCqSrJL59aR8a2xd-JY2bynRMLJS_ZfRzpRTR2ojSg03My1WSohKcajVlpBsk6LflyqoFGSKfQBkl5BKV_P525GH7Y_iQJbBcdvxh_o2tXHyeZWqyUELo_AT4jqBW99lH0sq1-tNle6Y20TfECrltj-1ArugCMUUUHemaBnIaK3Iuu3yg6V27XhS0QG6_x7LOI-UrrXCXezpbxTNXsYCXqlomsdqN0y_hVAS1Q0wlFLLpWM0gRT3uF6suj9-WBNcmTVdeNdMZFRb8U" />
                    </div>
                    <div class="p-6">
                        <span class="px-2 py-1 rounded-md bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400 text-[10px] font-bold uppercase tracking-wider">Databases</span>
                        <h3 class="text-xl font-bold mt-3 mb-2 text-slate-900 dark:text-white">Oracle NoSQL Essentials</h3>
                        <p class="text-slate-500 text-sm mb-6 line-clamp-2">Learn to design high-performance NoSQL architectures for high-volume data applications.</p>
                        <div class="flex items-center justify-between border-t border-slate-100 dark:border-slate-700 pt-4">
                            <span class="text-lg font-bold text-slate-900 dark:text-white">$279</span>
                            <a href="/Home/courses" class="text-primary font-bold text-sm">Enroll Now</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section - Entrance Exams -->
    <section class="py-24 px-4">
        <div class="max-w-5xl mx-auto rounded-3xl bg-primary px-8 py-16 text-center text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-32 -mt-32 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-black/10 rounded-full -ml-32 -mb-32 blur-3xl"></div>
            <h2 class="text-3xl md:text-5xl font-black mb-6 relative z-10">Ready to take the first step?</h2>
            <p class="text-lg md:text-xl text-white/80 mb-10 max-w-2xl mx-auto relative z-10">
                Check out our upcoming entrance exams and secure your spot in the next cohort. Scholarships available for top performers.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center relative z-10">
                <a href="/EntranceExam/Index" class="bg-white text-primary px-8 py-4 rounded-xl text-lg font-bold hover:bg-slate-100 transition-all">
                    View Exam Calendar
                </a>
                <a href="/Home/contact" class="bg-primary border border-white/30 text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-white/10 transition-all">
                    Request a Brochure
                </a>
            </div>
        </div>
    </section>
</main>