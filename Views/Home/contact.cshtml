@{
    ViewData["Title"] = "Contact Us";
}

<main class="flex-1">
    <div class="mx-auto max-w-[1200px] px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Contact Info -->
            <div class="flex flex-col gap-8">
                <div>
                    <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-4">Get in Touch</h1>
                    <p class="text-slate-600 dark:text-slate-400 text-lg">Have questions about our programs or certifications? Our team is here to help you navigate your IT career path.</p>
                </div>

                <div class="space-y-6">
                    <div class="flex gap-4 items-start">
                        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                            <span class="material-symbols-outlined">location_on</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-slate-900 dark:text-white">Main Branch</h3>
                            <p class="text-slate-500 text-sm">Symphony Towers, IT Park, Block 4, Sector 12</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start">
                        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                            <span class="material-symbols-outlined">call</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-slate-900 dark:text-white">Admissions</h3>
                            <p class="text-slate-500 text-sm">+1 (555) 000-1234</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start">
                        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                            <span class="material-symbols-outlined">mail</span>
                        </div>
                        <div>
                            <h3 class="font-bold text-slate-900 dark:text-white">Email Us</h3>
                            <p class="text-slate-500 text-sm">support@symphonyltd.com</p>
                        </div>
                    </div>
                </div>

                <div class="mt-4 p-6 bg-slate-50 dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800">
                    <h4 class="font-bold mb-2 text-slate-900 dark:text-white">Operating Hours</h4>
                    <div class="flex justify-between text-sm mb-2">
                        <span class="text-slate-500">Monday - Friday</span>
                        <span class="font-medium text-slate-700 dark:text-slate-300">9:00 AM - 8:00 PM</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-500">Saturday</span>
                        <span class="font-medium text-slate-700 dark:text-slate-300">10:00 AM - 4:00 PM</span>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-800">
                <form asp-action="contact" method="post" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">First Name</label>
                            <input name="name" type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="John" required />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Last Name</label>
                            <input name="name" type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="Doe" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Email Address</label>
                        <input name="email" type="email" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="john@example.com" required />
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Subject</label>
                        <input name="subject" type="text" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="How can we help?" required />
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Message</label>
                        <textarea name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary outline-none transition-all dark:text-white" placeholder="Tell us more about your inquiry..." required></textarea>
                    </div>
                    <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/25 transition-all flex items-center justify-center gap-2">
                        Send Message <span class="material-symbols-outlined text-sm">send</span>
                    </button>
                </form>
            </div>
        </div>

        <!-- Branches Map Placeholder -->
        <div class="mt-20">
            <div class="text-center mb-10">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white underline decoration-primary decoration-4 underline-offset-8">Our Global Presence</h2>
            </div>
            <div class="w-full h-[400px] rounded-3xl overflow-hidden shadow-inner border border-slate-100 dark:border-slate-800 bg-slate-100 dark:bg-slate-800 relative group">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15228.328472402123!2d78.361905!3d17.443909!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bcb93f0b8f0a0a0%3A0x0!2zMTfCsDI2JzM4LjAiTiA3OMKwMjEnNDIuOSJF!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</main>