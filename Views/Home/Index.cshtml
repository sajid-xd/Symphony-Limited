@{
    ViewData["Title"] = "Home Page";
}

<main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div class="flex flex-col gap-8">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                        </span>
                        Enrolling for @DateTime.Now.Year
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-black leading-tight tracking-tight text-slate-900 dark:text-white">
                        Master the <span class="text-primary">Future</span> of IT
                    </h1>
                    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-xl">
                        Industry-leading certification training in Networking, Java, and Databases. Elevate your career with expert-led courses designed for the modern tech landscape.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="/Home/courses" class="bg-primary text-white px-8 py-4 rounded-xl text-base font-bold hover:shadow-lg hover:shadow-primary/30 transition-all">
                            Explore Courses
                        </a>
                        <a href="/EntranceExam/Index" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-8 py-4 rounded-xl text-base font-bold hover:bg-slate-50 dark:hover:bg-slate-700 transition-all text-slate-900 dark:text-white">
                            View Entrance Exams
                        </a>
                    </div>
                    <div class="flex items-center gap-6 text-slate-500">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">verified</span>
                            <span class="text-sm font-medium">Certified Instructors</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">workspace_premium</span>
                            <span class="text-sm font-medium">Global Accreditation</span>
                        </div>
                    </div>
                </div>
                <div class="relative">
                    <div class="aspect-video w-full rounded-2xl bg-slate-200 dark:bg-slate-800 overflow-hidden shadow-2xl ring-1 ring-slate-200 dark:ring-slate-700">
                        <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBcDqYPHITP01_Qo_0FUwYanG5LMamy-L8lBwPpjr9RYoINMdCoFs0AY_lhezp-czr-jeWKV5HGi_rjnx8O76Ney2phDL-MdX43JtvtjUonTpjUZ77WHYvAw_OzIY7uG6B-yOq46WOL7n0yhTPfJO8dAY_LSX1aZsHiS8EWSHn6EI_QFW82dZOBN5ZPJbgWrldAAmJqM4vNfpnkFZCjEWXOFJu_G6ClhdBiXuXjtO7a-h6Erg8WIB2Qv_TRWeMvfk92UFmgxBSIapw" />
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-800 p-6 rounded-xl shadow-xl border border-slate-100 dark:border-slate-700 max-w-xs hidden sm:block">
                        <p class="text-sm font-bold text-primary mb-1">Upcoming Exam</p>
                        <p class="text-base font-semibold text-slate-900 dark:text-white">Java SE 17 Developer Certification</p>
                        <p class="text-xs text-slate-500 mt-2">Next window: @DateTime.Now.AddMonths(1).ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- About Us Summary -->
    <section class="py-20 bg-slate-100 dark:bg-slate-900/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-3 gap-12 items-start">
                <div class="lg:col-span-1">
                    <h2 class="text-3xl font-bold mb-4 text-slate-900 dark:text-white">Empowering Your Tech Journey</h2>
                    <div class="w-20 h-1.5 bg-primary rounded-full mb-6"></div>
                </div>
                <div class="lg:col-span-2">
                    <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
                        Symphony Limited is a premier IT and Software training institute dedicated to bridging the skills gap. With a focus on practical knowledge and global certifications, we prepare students for the evolving demands of the tech industry. Our mission is to transform learners into leaders through rigorous training and real-world projects.
                    </p>
                    <div class="grid sm:grid-cols-3 gap-8 mt-12">
                        <div>
                            <h3 class="text-4xl font-black text-primary mb-1">15k+</h3>
                            <p class="text-sm font-medium text-slate-500">Students Graduated</p>
                        </div>
                        <div>
                            <h3 class="text-4xl font-black text-primary mb-1">98%</h3>
                            <p class="text-sm font-medium text-slate-500">Placement Rate</p>
                        </div>
                        <div>
                            <h3 class="text-4xl font-black text-primary mb-1">50+</h3>
                            <p class="text-sm font-medium text-slate-500">Expert Courses</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- New Courses Section -->
