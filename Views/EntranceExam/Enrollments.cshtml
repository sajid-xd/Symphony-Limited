@model IEnumerable<SymphonyLimited.Models.ExamEnrollment>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Exam Enrollments";
}

<div class="mb-8">
    <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-2">Exam Enrollments</h1>
    <p class="text-slate-500 font-medium">Manage and view all students enrolled in entrance exams.</p>
</div>

<div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-xl shadow-slate-200/50 p-8 border border-slate-100 dark:border-slate-800">
    <table class="table w-full text-left border-collapse">
        <thead>
            <tr>
                <th>Enrollment ID</th>
                <th>Hall Ticket</th>
                <th>User Email</th>
                <th>Target Course</th>
                <th>Exam Date</th>
                <th>Enroll Date</th>
                <th>Status</th>
                <th class="text-right">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="font-mono text-sm font-black text-primary px-3 py-1 bg-primary/10 border border-primary/20 rounded-md">
                                @(item.HallTicketNumber ?? "HT-N/A")
                            </span>
                        </td>
                        <td>
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-xs shadow-sm">
                                    @(!string.IsNullOrEmpty(item.UserEmail) ? item.UserEmail.Substring(0,1).ToUpper() : "U")
                                </div>
                                <span class="font-bold text-slate-700">@item.UserEmail</span>
                            </div>
                        </td>
                        <td>
                            <span class="inline-block px-3 py-1 bg-slate-100 text-slate-600 rounded-lg text-xs font-semibold">
                                @(item.Course?.CourseName ?? "N/A")
                            </span>
                        </td>
                        <td class="text-sm font-medium">@item.EntranceExam.ExamDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <span class="px-3 py-1 bg-slate-100/50 text-slate-500 rounded-lg text-xs font-medium">
                                @item.EnrollmentDate.ToString("MMM dd, yyyy hh:mm tt")
                            </span>
                        </td>
                        <td>
                            @if (item.Status == "Passed")
                            {
                                <span class="px-3 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-xs font-bold uppercase tracking-wide">Passed</span>
                            }
                            else if (item.Status == "Failed")
                            {
                                <span class="px-3 py-1 bg-red-100 text-red-700 rounded-lg text-xs font-bold uppercase tracking-wide">Failed</span>
                            }
                            else
                            {
                                <span class="px-3 py-1 bg-amber-100 text-amber-700 rounded-lg text-xs font-bold uppercase tracking-wide">Pending</span>
                            }
                        </td>
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <form asp-action="UpdateStatus" method="post" class="m-0 p-0">
                                    <input type="hidden" name="id" value="@item.EnrollmentId" />
                                    <!-- Status Dropdown (or quick buttons) -->
                                    <div class="flex gap-1">
                                        <button type="submit" name="status" value="Passed" class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 hover:bg-emerald-500 hover:text-white flex items-center justify-center transition-colors" title="Mark Passed">
                                            <span class="material-symbols-outlined text-[18px]">done</span>
                                        </button>
                                        <button type="submit" name="status" value="Failed" class="w-8 h-8 rounded-lg bg-red-50 text-red-600 hover:bg-red-500 hover:text-white flex items-center justify-center transition-colors" title="Mark Failed">
                                            <span class="material-symbols-outlined text-[18px]">close</span>
                                        </button>
                                        <button type="submit" name="status" value="Pending" class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 hover:bg-amber-500 hover:text-white flex items-center justify-center transition-colors" title="Mark Pending">
                                            <span class="material-symbols-outlined text-[18px]">history</span>
                                        </button>
                                    </div>
                                </form>
                                <form asp-action="DeleteEnrollment" method="post" class="m-0 p-0 ml-2" onsubmit="return confirm('Are you sure you want to completely delete this enrollment?');">
                                    <input type="hidden" name="id" value="@item.EnrollmentId" />
                                    <button type="submit" class="w-8 h-8 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-900 hover:text-white flex items-center justify-center transition-colors shadow-sm" title="Delete record">
                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
