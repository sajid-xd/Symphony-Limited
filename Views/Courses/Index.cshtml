@model IEnumerable<SymphonyLimited.Models.Course>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    /* Prevent table cells from wrapping */
    #coursesTable th,
    #coursesTable td {
        white-space: nowrap;
    }
</style>

<main style="margin-top: 58px">
    <div class="container pt-4">
        <section>
            <div class="container-fluid mt-4">
                <div class="d-flex justify-content-between mb-3">
                    <a asp-action="Create" class="btn btn-primary">Create</a>
                    <a asp-action="ViewTrash" class="btn btn-danger">Trashed (@ViewBag.TrashedCount)</a>
                </div>
                <div class="table-responsive">
                    <table id="coursesTable" class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>SNo #</th>
                            <th>Course Name</th>
                            <th>Description</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Basic Fees</th>
                            <th>Advanced Fees</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 0;
                        }
                        @if (Model != null && Model.Any())
                        {
                            foreach (var course in Model)
                            {
                                i++;
                                <tr>
                                    <td>@i</td>
                                    <td>@course.CourseName</td>
                                    <td>@course.Description</td>
                                    <td>@course.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@course.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@course.BasicFees</td>
                                    <td>@course.AdvancedFees</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@course.CourseId" class="btn btn-sm btn-warning">Edit</a>
                                        <a asp-action="Trash" asp-route-id="@course.CourseId" class="btn btn-sm btn-danger">Trash</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">No courses available</td>
                            </tr>
                        }
                    </tbody>

                </table>
                </div>
            </div>
        </section>
        <!--Section: Statistics with subtitles-->
    </div>
</main>